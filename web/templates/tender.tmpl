<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ .Bid.BidNumber }} — GEM Tender</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body class="bg-slate-50 min-h-screen">
    <!-- Fixed top nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-slate-900">
        <div class="flex items-center justify-between px-6 py-3">
            <a href="/" class="text-white font-semibold text-lg no-underline">GEM Tender Discovery</a>
            <div class="flex gap-4">
                <a href="/" class="text-slate-400 hover:text-white text-sm no-underline">Search</a>
                <a href="/dashboard" class="text-slate-400 hover:text-white text-sm no-underline">Dashboard</a>
            </div>
        </div>
    </nav>

    <!-- Main content -->
    <main class="max-w-5xl mx-auto px-6 py-8 pt-24">
        <!-- Back link -->
        <a href="/" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-slate-900 transition-colors mb-6 no-underline">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
            </svg>
            Back to search
        </a>

        <!-- Header card -->
        <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-sm mb-6">
            <div class="flex items-center gap-3">
                <h2 class="text-xl font-bold text-slate-900">{{ .Bid.BidNumber }}</h2>
                {{ if eq .Bid.IsHighValue 1 }}
                <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-amber-100 text-amber-800">High Value</span>
                {{ end }}
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mt-5">
                <div>
                    <div class="text-xs uppercase tracking-wider text-slate-400 font-semibold">Category</div>
                    <div class="text-sm text-slate-800 mt-1">{{ .Bid.CategoryName }}</div>
                </div>
                <div>
                    <div class="text-xs uppercase tracking-wider text-slate-400 font-semibold">Ministry</div>
                    <div class="text-sm text-slate-800 mt-1">{{ .Bid.MinistryName }}</div>
                </div>
                <div>
                    <div class="text-xs uppercase tracking-wider text-slate-400 font-semibold">Department</div>
                    <div class="text-sm text-slate-800 mt-1">{{ .Bid.DepartmentName }}</div>
                </div>
                <div>
                    <div class="text-xs uppercase tracking-wider text-slate-400 font-semibold">Quantity</div>
                    <div class="text-sm text-slate-800 mt-1">{{ .Bid.TotalQuantity }}</div>
                </div>
                <div>
                    <div class="text-xs uppercase tracking-wider text-slate-400 font-semibold">Start Date</div>
                    <div class="text-sm text-emerald-600 mt-1">{{ .Bid.StartDate | formatDate }}</div>
                </div>
                <div>
                    <div class="text-xs uppercase tracking-wider text-slate-400 font-semibold">End Date</div>
                    <div class="text-sm text-red-500 mt-1">{{ .Bid.EndDate | formatDate }}</div>
                </div>
                {{ if .Bid.BidNumberParent }}
                <div>
                    <div class="text-xs uppercase tracking-wider text-slate-400 font-semibold">Parent Bid</div>
                    <div class="text-sm text-slate-800 mt-1">{{ .Bid.BidNumberParent }}</div>
                </div>
                {{ end }}
            </div>
        </div>

        <!-- Corrigendum / Representation section -->
        {{ if .OtherDetails }}
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm mb-6 overflow-hidden">
            <!-- Tab bar -->
            <div class="border-b border-slate-200 px-6 pt-4 flex">
                {{ if eq .OtherDetails.HasCorrigendum 1 }}
                <button class="tab-btn pb-3 px-1 mr-6 text-sm font-medium border-b-2 border-blue-600 text-blue-600 bg-transparent cursor-pointer" onclick="showTab('corrigendum')">
                    Corrigendum
                    <span class="bg-orange-500 text-white text-xs px-2 py-0.5 rounded-full ml-2">{{ .OtherDetails.CorrigendumCount }}</span>
                </button>
                {{ end }}
                {{ if eq .OtherDetails.HasRepresentation 1 }}
                <button class="tab-btn pb-3 px-1 mr-6 text-sm font-medium border-b-2 bg-transparent cursor-pointer {{ if ne .OtherDetails.HasCorrigendum 1 }}border-blue-600 text-blue-600{{ else }}border-transparent text-slate-500 hover:text-slate-700{{ end }}" onclick="showTab('representation')">
                    Representation
                </button>
                {{ end }}
            </div>

            <!-- Tab content -->
            {{ if eq .OtherDetails.HasCorrigendum 1 }}
            <div id="tab-corrigendum" class="tab-content p-6">
                {{ if .CorrDocs }}
                <h4 class="text-sm font-semibold text-slate-700 mb-3">Corrigendum Documents</h4>
                <div class="mb-4">
                    {{ range .CorrDocs }}
                    <div class="flex items-center gap-4 py-3 border-b border-slate-100">
                        {{ if eq .Downloaded 1 }}
                        <a href="/corrigendum-pdf/{{ .CorrigendumID }}/{{ .BidID }}" class="text-blue-600 hover:text-blue-800 font-medium text-sm no-underline">Download PDF</a>
                        {{ else }}
                        <span class="text-slate-400 italic text-sm">Pending download</span>
                        {{ end }}
                        {{ if .ModifiedOn }}
                        <span class="text-xs text-slate-400">Modified: {{ .ModifiedOn }}</span>
                        {{ end }}
                    </div>
                    {{ end }}
                </div>
                {{ end }}
                <div class="corr-html">
                    {{ .OtherDetails.CorrigendumHTML | safeHTML }}
                </div>
            </div>
            {{ end }}

            {{ if eq .OtherDetails.HasRepresentation 1 }}
            <div id="tab-representation" class="tab-content p-6"{{ if eq .OtherDetails.HasCorrigendum 1 }} style="display:none;"{{ end }}>
                <div class="repr-html">
                    {{ .OtherDetails.RepresentationHTML | safeHTML }}
                </div>
            </div>
            {{ end }}
        </div>

        <script>
        function showTab(name) {
            document.querySelectorAll('.tab-content').forEach(function(el) { el.style.display = 'none'; });
            document.querySelectorAll('.tab-btn').forEach(function(el) {
                el.classList.remove('border-blue-600', 'text-blue-600');
                el.classList.add('border-transparent', 'text-slate-500');
            });
            document.getElementById('tab-' + name).style.display = 'block';
            event.currentTarget.classList.remove('border-transparent', 'text-slate-500');
            event.currentTarget.classList.add('border-blue-600', 'text-blue-600');
        }
        </script>
        {{ end }}

        <!-- PDF card -->
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <h3 class="text-lg font-semibold text-slate-800 p-6 border-b border-slate-100">Bid Document</h3>
            <iframe src="/pdf/{{ .PDFID }}" class="w-full border-0" style="height:800px;"></iframe>
        </div>
    </main>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — GEM Tender Discovery</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body class="bg-slate-50 min-h-screen">
    <!-- Fixed top nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-slate-900">
        <div class="flex items-center justify-between px-6 py-3">
            <a href="/" class="text-white font-semibold text-lg no-underline">GEM Tender Discovery</a>
            <div class="flex gap-4">
                <a href="/" class="text-slate-400 hover:text-white text-sm no-underline">Search</a>
                <a href="/dashboard" class="text-white text-sm no-underline underline underline-offset-4">Dashboard</a>
            </div>
        </div>
    </nav>

    <!-- Scrape Confirmation Modal -->
    <div id="scrape-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center">
        <div class="absolute inset-0 bg-black/50" onclick="hideScrapeModal()"></div>
        <div class="relative bg-white rounded-xl shadow-xl p-6 max-w-md w-full mx-4">
            <h3 class="text-lg font-semibold text-slate-900 mb-4">Confirm Scrape</h3>
            <p class="text-sm text-slate-600 mb-3">The following tasks will be run:</p>
            <ul id="modal-task-list" class="list-disc list-inside text-sm text-slate-700 mb-6 space-y-1"></ul>
            <div class="flex justify-end gap-3">
                <button onclick="hideScrapeModal()" class="px-4 py-2 text-sm text-slate-500 hover:text-slate-800 cursor-pointer bg-transparent border-none">Cancel</button>
                <button onclick="confirmScrape()" class="px-4 py-2 bg-slate-900 hover:bg-slate-800 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer">Start</button>
            </div>
        </div>
    </div>

    <!-- Main content -->
    <main class="max-w-7xl mx-auto px-6 py-8 pt-24">

        <!-- 1. Scrape Controls -->
        <section class="mb-8">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Scrape Controls</h2>
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
                <div class="flex flex-wrap gap-3">
                    <button onclick="showScrapeModal(['scrape'])" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer">Scrape Bids</button>
                    <button onclick="showScrapeModal(['download'])" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer">Download PDFs</button>
                    <button onclick="showScrapeModal(['corrigendum'])" class="px-4 py-2 bg-orange-600 hover:bg-orange-700 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer">Check Corrigendums</button>
                    <button onclick="showScrapeModal(['scrape','download','corrigendum'])" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer">Run All</button>
                </div>

                <!-- Progress Panel (hidden until scrape starts) -->
                <div id="scrape-progress" class="hidden mt-5 pt-5 border-t border-slate-200">
                    <div class="flex items-center justify-between mb-2">
                        <span id="progress-task" class="text-sm font-medium text-slate-700">—</span>
                        <span id="progress-pct" class="text-sm font-semibold text-blue-600">0%</span>
                    </div>
                    <div class="w-full bg-slate-200 rounded-full h-2.5 mb-3">
                        <div id="progress-bar" class="bg-blue-500 h-2.5 rounded-full transition-all duration-300" style="width:0%"></div>
                    </div>
                    <p id="progress-message" class="text-xs text-slate-500 mb-3"></p>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                        <div><span class="text-slate-400">Processed:</span> <span id="stat-processed" class="text-slate-700 font-medium">0</span></div>
                        <div><span class="text-slate-400">Total:</span> <span id="stat-total" class="text-slate-700 font-medium">0</span></div>
                        <div><span class="text-slate-400">Errors:</span> <span id="stat-errors" class="text-slate-700 font-medium">0</span></div>
                        <div><span class="text-slate-400">Elapsed:</span> <span id="stat-elapsed" class="text-slate-700 font-medium">—</span></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 2. Overview Stats -->
        <section class="mb-8">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Overview</h2>
            <div id="summary-stats" class="grid grid-cols-2 lg:grid-cols-4 gap-4"
                 hx-get="/api/stats/summary" hx-trigger="load" hx-swap="innerHTML">
                <!-- Populated via HTMX / JS -->
                <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 animate-pulse"><div class="h-16 bg-slate-100 rounded"></div></div>
                <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 animate-pulse"><div class="h-16 bg-slate-100 rounded"></div></div>
                <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 animate-pulse"><div class="h-16 bg-slate-100 rounded"></div></div>
                <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 animate-pulse"><div class="h-16 bg-slate-100 rounded"></div></div>
            </div>
        </section>

        <!-- 3. Tender Pipeline -->
        <section class="mb-8">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Tender Pipeline</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div id="pipeline-stats" class="bg-white rounded-xl border border-slate-200 shadow-sm p-5"
                     hx-get="/api/stats/pipeline" hx-trigger="load" hx-swap="innerHTML">
                    <div class="animate-pulse space-y-3">
                        <div class="h-4 bg-slate-100 rounded w-3/4"></div>
                        <div class="h-4 bg-slate-100 rounded w-2/3"></div>
                        <div class="h-4 bg-slate-100 rounded w-1/2"></div>
                    </div>
                </div>
                <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
                    <canvas id="pipelineChart" height="220"></canvas>
                </div>
            </div>
        </section>

        <!-- 4. Breakdowns -->
        <section class="mb-8">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Breakdowns</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
                    <h3 class="text-sm font-semibold text-slate-700 mb-3">Top 10 Departments</h3>
                    <canvas id="deptChart" height="300"></canvas>
                </div>
                <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
                    <h3 class="text-sm font-semibold text-slate-700 mb-3">Top 10 Categories</h3>
                    <canvas id="catChart" height="300"></canvas>
                </div>
            </div>
        </section>

        <!-- 5. Timeline -->
        <section class="mb-8">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Timeline</h2>
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
                <h3 class="text-sm font-semibold text-slate-700 mb-3">Bids Added (Last 30 Days)</h3>
                <canvas id="timelineChart" height="120"></canvas>
            </div>
        </section>

    </main>

    <script>
    // ── Chart.js defaults ──
    Chart.defaults.color = '#64748b';

    // ── Scrape Modal ──
    let pendingTasks = [];

    function showScrapeModal(tasks) {
        pendingTasks = tasks;
        const list = document.getElementById('modal-task-list');
        const labels = { scrape: 'Scrape Bids', download: 'Download PDFs', corrigendum: 'Check Corrigendums' };
        list.innerHTML = tasks.map(t => '<li>' + (labels[t] || t) + '</li>').join('');
        document.getElementById('scrape-modal').classList.remove('hidden');
    }

    function hideScrapeModal() {
        document.getElementById('scrape-modal').classList.add('hidden');
        pendingTasks = [];
    }

    function confirmScrape() {
        const tasks = [...pendingTasks];
        hideScrapeModal();
        fetch('/api/scrape/start', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tasks: tasks })
        }).then(r => r.json()).then(data => {
            if (data.status === 'started') {
                connectSSE();
            } else {
                alert(data.error || 'Failed to start scrape');
            }
        }).catch(err => console.error('Failed to start scrape:', err));
    }

    // ── SSE Progress ──
    let evtSource = null;

    function connectSSE() {
        if (evtSource) evtSource.close();
        const panel = document.getElementById('scrape-progress');
        panel.classList.remove('hidden');

        evtSource = new EventSource('/api/scrape/progress');

        evtSource.onmessage = function(e) {
            try {
                const d = JSON.parse(e.data);
                document.getElementById('progress-task').textContent = d.task || '—';
                document.getElementById('progress-message').textContent = d.message || '';
                const pct = d.total > 0 ? Math.round((d.current / d.total) * 100) : 0;
                document.getElementById('progress-pct').textContent = pct + '%';
                document.getElementById('progress-bar').style.width = pct + '%';
                document.getElementById('stat-processed').textContent = d.current || 0;
                document.getElementById('stat-total').textContent = d.total || 0;
                document.getElementById('stat-errors').textContent = d.errors || 0;
                document.getElementById('stat-elapsed').textContent = Math.round(d.elapsed_sec || 0) + 's';

                if (d.status === 'completed') {
                    evtSource.close();
                    evtSource = null;
                    // Refresh stats
                    htmx.trigger('#summary-stats', 'load');
                    htmx.trigger('#pipeline-stats', 'load');
                    loadCharts();
                }
            } catch(err) {
                console.error('SSE parse error:', err);
            }
        };

        evtSource.onerror = function() {
            evtSource.close();
            evtSource = null;
        };
    }

    // ── Check if scrape already running ──
    fetch('/api/scrape/status').then(r => r.json()).then(d => {
        if (d.running) connectSSE();
    }).catch(() => {});

    // ── HTMX: intercept JSON responses for summary stats ──
    document.addEventListener('htmx:beforeSwap', function(evt) {
        if (evt.detail.target.id === 'summary-stats') {
            try {
                const data = JSON.parse(evt.detail.serverResponse);
                evt.detail.serverResponse = renderSummaryCards(data);
            } catch(e) {
                // If it's already HTML, let it through
            }
        }
        if (evt.detail.target.id === 'pipeline-stats') {
            try {
                const data = JSON.parse(evt.detail.serverResponse);
                evt.detail.serverResponse = renderPipelineStats(data);
                // Update pipeline chart
                updatePipelineChart(data);
            } catch(e) {}
        }
    });

    function renderSummaryCards(d) {
        return `
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4">
                <div class="text-xs text-slate-400 uppercase tracking-wide font-medium">Total Bids</div>
                <div class="text-2xl font-bold text-slate-900 mt-1">${(d.total_bids || 0).toLocaleString()}</div>
            </div>
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4">
                <div class="text-xs text-slate-400 uppercase tracking-wide font-medium">PDFs Downloaded</div>
                <div class="text-2xl font-bold text-slate-900 mt-1">${(d.pdfs_downloaded || 0).toLocaleString()}</div>
                <div class="text-xs text-slate-400 mt-1">${(d.pdfs_pending || 0).toLocaleString()} pending</div>
            </div>
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4">
                <div class="text-xs text-slate-400 uppercase tracking-wide font-medium">Corrigendum Docs</div>
                <div class="text-2xl font-bold text-slate-900 mt-1">${(d.corr_docs_tracked || 0).toLocaleString()}</div>
                <div class="text-xs text-slate-400 mt-1">${(d.corr_docs_downloaded || 0).toLocaleString()} downloaded</div>
            </div>
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4">
                <div class="text-xs text-slate-400 uppercase tracking-wide font-medium">Bids Last 24h</div>
                <div class="text-2xl font-bold text-slate-900 mt-1">${(d.bids_last_24h || 0).toLocaleString()}</div>
                <div class="text-xs text-slate-400 mt-1">Last scrape: ${d.last_scrape_time || 'N/A'}</div>
            </div>
        `;
    }

    function renderPipelineStats(d) {
        return `
            <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-slate-100">
                    <span class="text-sm text-slate-600">Active</span>
                    <span class="text-sm font-semibold text-slate-900">${(d.active || 0).toLocaleString()}</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-slate-100">
                    <span class="text-sm text-slate-600">Expired</span>
                    <span class="text-sm font-semibold text-slate-900">${(d.expired || 0).toLocaleString()}</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-slate-100">
                    <span class="text-sm text-slate-600">Closing in 24h</span>
                    <span class="text-sm font-semibold text-red-600">${(d.closing_24h || 0).toLocaleString()}</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-slate-100">
                    <span class="text-sm text-slate-600">Closing in 48h</span>
                    <span class="text-sm font-semibold text-orange-600">${(d.closing_48h || 0).toLocaleString()}</span>
                </div>
                <div class="flex justify-between items-center py-2">
                    <span class="text-sm text-slate-600">Closing in 7d</span>
                    <span class="text-sm font-semibold text-slate-900">${(d.closing_7d || 0).toLocaleString()}</span>
                </div>
            </div>
        `;
    }

    // ── Charts ──
    let pipelineChart, deptChart, catChart, timelineChart;

    function updatePipelineChart(data) {
        const ctx = document.getElementById('pipelineChart').getContext('2d');
        if (pipelineChart) pipelineChart.destroy();
        pipelineChart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Active', 'Expired'],
                datasets: [{
                    data: [data.active || 0, data.expired || 0],
                    backgroundColor: ['#10b981', '#94a3b8'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });
    }

    function loadCharts() {
        // Departments bar chart
        fetch('/api/stats/departments').then(r => r.json()).then(data => {
            const ctx = document.getElementById('deptChart').getContext('2d');
            if (deptChart) deptChart.destroy();
            deptChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.map(d => d.name),
                    datasets: [{
                        data: data.map(d => d.count),
                        backgroundColor: '#3b82f6'
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { color: '#e2e8f0' } },
                        y: { grid: { display: false } }
                    }
                }
            });
        }).catch(() => {});

        // Categories bar chart
        fetch('/api/stats/categories').then(r => r.json()).then(data => {
            const ctx = document.getElementById('catChart').getContext('2d');
            if (catChart) catChart.destroy();
            catChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.map(d => d.name),
                    datasets: [{
                        data: data.map(d => d.count),
                        backgroundColor: '#f59e0b'
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { color: '#e2e8f0' } },
                        y: { grid: { display: false } }
                    }
                }
            });
        }).catch(() => {});

        // Timeline line chart
        fetch('/api/stats/timeline').then(r => r.json()).then(data => {
            const ctx = document.getElementById('timelineChart').getContext('2d');
            if (timelineChart) timelineChart.destroy();
            timelineChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.map(d => d.date),
                    datasets: [{
                        label: 'Bids Added',
                        data: data.map(d => d.count),
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59,130,246,0.1)',
                        tension: 0.3,
                        pointRadius: 3,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { color: '#e2e8f0' } },
                        y: { grid: { color: '#e2e8f0' }, beginAtZero: true }
                    }
                }
            });
        }).catch(() => {});
    }

    // Load charts on page load
    document.addEventListener('DOMContentLoaded', loadCharts);
    </script>
</body>
</html>
